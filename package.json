{
  "name": "finalnodejs",
  "version": "1.0.0",
  "description": "Chat API with Clean Architecture",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node -r tsconfig-paths/register src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "test": "jest",
    "test:unit": "jest --testPathPattern=\"\\.(test|spec)\\.ts$\"",
    "test:integration": "jest --testPathPattern=\"integration\"",
    "test:e2e": "jest --testPathPattern=\"e2e\"",
    "lint": "echo \"No linter configured\"",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "chat",
    "api",
    "clean-architecture",
    "typescript"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/helmet": "^0.0.48",
    "@types/ioredis-mock": "^8.2.7",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mongoose": "^5.11.96",
    "@types/node": "^18.19.130",
    "@types/redis": "^4.0.10",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "ioredis-mock": "^8.13.1",
    "jest": "^30.3.0",
    "mongodb-memory-server": "^11.0.1",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0"
  },
  "dependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "axios": "^1.15.2",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.5.0",
    "react-query": "^3.39.3",
    "redis": "^5.12.1",
    "uuid": "^14.0.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  }
}
